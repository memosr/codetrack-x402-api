# --- x402 / Base Builder identity ---
# Base mainnet address that receives the USDC payments (the x402 payTo).
PAY_TO_ADDRESS=
# Coinbase CDP API key used to sign verify/settle requests to the production
# x402 facilitator (https://api.cdp.coinbase.com/platform/v2/x402).
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# --- CodeTrack Supabase (public read keys) ---
# Same anon/publishable key the CodeTrack frontend ships; read-only, safe to use.
CODETRACK_SUPABASE_URL=https://your-project.supabase.co
CODETRACK_SUPABASE_ANON_KEY=sb_publishable_xxx

# --- Service config ---
# Base Builder Code (ERC-8021 Schema 2 "a") used for settlement attribution.
BUILDER_CODE=bc_lhfd8zad
# Port the Express server listens on.
PORT=4022
